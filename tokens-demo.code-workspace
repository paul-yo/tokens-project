{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"js/ts.tsdk.path": "node_modules/typescript/lib",
		"js/ts.tsdk.promptToUseWorkspaceVersion": true,
		"files.exclude": {
			"dist": true
		},
	},
	"launch": {
		"version": "0.2.0",
		"configurations": [
			{
				"type": "node",
				"request": "launch",
				"name": "Debug Project",
				"program": "src/index.ts",
				"skipFiles": [
					"<node_internals>/**"
				],
				"console": "integratedTerminal"
			}
		]
	}
}