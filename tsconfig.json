{
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": [
			"dom",
			"esnext"
		],
		"types": [
			"node"
		],
		"allowImportingTsExtensions": true,
		"allowJs": true,
		"checkJs": false,
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"resolveJsonModule": true
	},
}
