
Animal
(
	eat()
	(
		console.log("Bunny.eat")
	)
)

Bunny is Animal
(
	foo(a is string, b is u32)
	(
		console.log("aaa")
		
		if (value == 1) (
			console.log("bbb")
		)
		
		items is u8[] = [2, 3, 4, 5]
		items each item (
			if (item > 3) (
				console.log("item is greater than 3")
			)
			else (
				console.log("item is less than or equal to 3")
			)
		)
	)
	
	eat()
	(
		super.eat()
	)
)
